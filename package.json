{
    "name": "arango-edge-patterns-erp",
    "version": "1.0.0",
    "description": "Enterprise ERP Edge Patterns Showcase - ArangoDB Hierarchical Data",
    "type": "module",
    "main": "dist/src/index.js",
    "scripts": {
        "dev": "nodemon --exec node --loader ts-node/esm src/server.ts",
        "build": "tsc",
        "start": "node dist/src/server.js",
        "seed": "NODE_OPTIONS='--loader ts-node/esm' node --input-type=module -e \"import('./src/db.ts').then(m => m.seedDatabase().then(() => process.exit(0)))\"",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [
        "arangodb",
        "graph",
        "edges",
        "erp",
        "hierarchy",
        "typescript"
    ],
    "author": "Your Name",
    "license": "MIT",
    "dependencies": {
        "arangojs": "^8.8.0",
        "cors": "^2.8.5",
        "dotenv": "^17.3.1",
        "express": "^4.18.2"
    },
    "devDependencies": {
        "@types/cors": "^2.8.14",
        "@types/express": "^4.17.17",
        "@types/node": "^20.0.0",
        "nodemon": "^3.0.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.0.0"
    }
}
